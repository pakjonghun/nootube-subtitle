{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NooTube Subtitle Extractor",
  "version": "0.5.0",
  "identifier": "com.jeonghunbag.nootube-subtitle-extractor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NooTube Subtitle Extractor",
        "width": 700,
        "height": 600,
        "resizable": true,
        "minWidth": 500,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/yt-dlp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
